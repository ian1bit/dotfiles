#!/bin/bash

# Gets the wifi status

WIFI_FULL_ICON='ď‡«'
WIFI_MID_ICON='ď‡«'
WIFI_LOW_ICON='ď‡«'
NO_WIFI_ICON=''
MYSSID=$(iwgetid -r)

get_wifi()
{
        if grep -q wl* "/proc/net/wireless"; then
                # Wifi quality percentage
                percentage=$(grep "^\s*w" /proc/net/wireless | awk '{ print "", int($3 * 100 / 70)}'| xargs)
                case $percentage in
                        0)                              echo $NO_WIFI_ICON;;
                        100|9[0-9]|8[0-9]|7[0-9])       echo "$MYSSID" ;;
                        6[0-9]|5[0-9]|4[0-9]|3[0-9])    echo "$MYSSID" ;;
                        2[0-9]|1[0-9]|[0-9])            echo "$MYSSID" ;;
                esac
        fi
}

get_wifi
